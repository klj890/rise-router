# 后端服务监听地址（禁用 8080：与微信客户端冲突）
RR_BIND_ADDR=0.0.0.0:8088

# PostgreSQL（SeaORM 运行期连接）
RR_DATABASE_URL=postgres://rise:rise@localhost:5432/rise_router

# 迁移 CLI 读取的变量（migration crate 使用标准 DATABASE_URL）
DATABASE_URL=postgres://rise:rise@localhost:5432/rise_router

# Redis（会话/限流/队列，M1 起使用）
RR_REDIS_URL=redis://localhost:6379

# 对象存储（S3 兼容，artifacts；M5 起使用）
RR_S3_ENDPOINT=http://localhost:9000
RR_S3_ACCESS_KEY=minioadmin
RR_S3_SECRET_KEY=minioadmin
RR_S3_BUCKET=rise-artifacts

# 日志级别
RR_LOG_LEVEL=info

# 管理操作令牌（手动充值等）。RBAC 落地前的临时守卫，请求需带 X-Admin-Token 头；留空则相关管理端点禁用。
RR_ADMIN_TOKEN=

# 用户会话 JWT 签名密钥（手机号+短信登录签发 token）。留空则用户登录端点禁用；生产请用强随机值。
RR_JWT_SECRET=

# 引导管理员手机号：该号登录时自动授予 admin 角色（解决 RBAC 首个 admin 的鸡生蛋）。留空则不引导。
RR_BOOTSTRAP_ADMIN_PHONE=

# SMTP 邮件发送（月度毛利月报）。HOST 或 FROM 留空 → 邮件功能禁用。
# 端口：465=隐式 TLS / 587=STARTTLS / 其他=明文（仅测试）。
RR_SMTP_HOST=
RR_SMTP_PORT=465
RR_SMTP_USER=
RR_SMTP_PASSWORD=
RR_SMTP_FROM=Rise Router <noreply@example.com>

# 月度毛利月报 cron（发给固定财务收件人；org 无邮箱，暂不做 per-org 客户账单）。
RR_BILLING_EMAIL_ENABLED=false
# 收件人，逗号/分号分隔
RR_BILLING_EMAIL_RECIPIENTS=
# 每月触发日（1-28）与小时（0-23，CST/UTC+8）：默认每月 1 号 9 点发上月月报
RR_BILLING_EMAIL_DAY=1
RR_BILLING_EMAIL_HOUR=9
# 演练模式：true 时只渲染 + 日志，不真发 SMTP（本地/无 SMTP 验证用）
RR_BILLING_EMAIL_DRY_RUN=false

# 渠道健康探活 + 被动恢复（默认关闭；单实例假设，多实例选主留后续）。
# 开启后：周期测 Enabled 渠道（失败/超时且 auto_ban → 熔断 CircuitBroken）+ 测 CircuitBroken（通过则恢复）。
RR_CHANNEL_HEALTH_ENABLED=false
# 探活周期（分钟，下限 1）
RR_CHANNEL_HEALTH_INTERVAL_MINUTES=10
# 响应时间阈值（ms，超过视为不健康触发熔断；0=不按耗时熔断）
RR_CHANNEL_HEALTH_RT_THRESHOLD_MS=5000
